# MongoDB Atlas connection string.
# In Atlas: Database > Connect > Drivers > Python, then copy the URI and swap in your DB user's
# username/password (URL-encode any special characters in the password).
MONGODB_URI=your_mongodb_atlas_connection_string

# Name of the database to use inside your Atlas cluster (created automatically on first write).
DATABASE_NAME=notes_app

# Comma-separated list of origins allowed to call this API.
CORS_ORIGINS=http://localhost:5173
